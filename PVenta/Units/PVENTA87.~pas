procedure TfrmConsComision.btVendedorClick(Sender: TObject);
begin
  search.AliasFields.clear;
  search.AliasFields.add('Nombre');
  search.AliasFields.add('Código');
  Search.Query.clear;
  Search.Query.add('select ven_nombre, ven_codigo');
  Search.Query.add('from vendedores');
  Search.Query.add('where emp_codigo = '+inttostr(dm.vp_cia));
  Search.ResultField := 'ven_Codigo';
  Search.Title := 'Listado de Vendedores';
  if Search.execute then
  begin
    edVendedor.text := Search.ValueField;
    dm.Query1.close;
    dm.Query1.sql.clear;
    dm.Query1.sql.add('select ven_nombre, ven_comision_venta, ven_comision_cobro from vendedores');
    dm.Query1.sql.add('where emp_codigo = :emp');
    dm.Query1.sql.add('and ven_codigo = :ven');
    dm.Query1.Parameters.parambyname('emp').Value := dm.vp_cia;
    dm.Query1.Parameters.parambyname('ven').Value := strtoint(trim(edVendedor.text));
    dm.Query1.open;
    ComVenta := 'False';
    ComCobro := 'False';
    if dm.Query1.recordcount = 0 then
      messagedlg('VENDEDOR NO EXISTE',mterror,[mbok],0)
    else
    begin
      tVendedor.text := dm.Query1.fieldbyname('ven_nombre').asstring;
      if not dm.Query1.fieldbyname('ven_comision_venta').IsNull then
        ComVenta := dm.Query1.fieldbyname('ven_comision_venta').Value;
      if not   dm.Query1.fieldbyname('ven_comision_cobro').IsNull then
        ComCobro := dm.Query1.fieldbyname('ven_comision_cobro').Value;
    end;
    edVendedor.setfocus;
    btRefreshClick(self);
  end;
end;

procedure TfrmConsComision.edVendedorChange(Sender: TObject);
begin
  if trim(edVendedor.text) = '' then tVendedor.text := '' else
  btRefreshClick(Sender);
end;

procedure TfrmConsComision.edVendedorKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin
  if key = vk_return then
  begin
    if trim(edVendedor.text) <> '' then
    begin
      dm.Query1.close;
      dm.Query1.sql.clear;
      dm.Query1.sql.add('select ven_nombre, ven_comision_venta, ven_comision_cobro from vendedores');
      dm.Query1.sql.add('where emp_codigo = :emp');
      dm.Query1.sql.add('and ven_codigo = :ven');
      dm.Query1.Parameters.parambyname('emp').Value := dm.vp_cia;
      dm.Query1.Parameters.parambyname('ven').Value := strtoint(trim(edVendedor.text));
      dm.Query1.open;
      ComVenta := 'False';
      ComCobro := 'False';
      if dm.Query1.recordcount = 0 then
      begin
        messagedlg('VENDEDOR NO EXISTE',mterror,[mbok],0);
        edVendedor.SetFocus;
      end
      else
      begin
        tVendedor.text := dm.Query1.fieldbyname('ven_nombre').asstring;
        if not dm.Query1.fieldbyname('ven_comision_venta').IsNull then
          ComVenta := dm.Query1.fieldbyname('ven_comision_venta').Value;
        if not   dm.Query1.fieldbyname('ven_comision_cobro').IsNull then
          ComCobro := dm.Query1.fieldbyname('ven_comision_cobro').Value;
      end;
      btRefreshClick(Self);
    end;
  end;
end;

procedure TfrmConsComision.btRefreshClick(Sender: TObject);
begin
    Screen.Cursor := crSQLWait;

    if PageControl1.ActivePage = tsFactura then begin
    with QConsulta do begin
    Close;
    SQL.Clear;
    SQL.Add('SELECT S.SUC_NOMBRE SUCURSAL, F.FAC_FORMA FORMA, F.TFA_CODIGO TIPO, F.FAC_NUMERO NUM, F.FAC_FECHA FEC,');
    SQL.Add('F.FAC_STATUS STA, F.FAC_NOMBRE CLIENTE, F.FAC_COMISION COMISION,');
    SQL.Add('(f.fac_total-f.fac_itbis) as TOTAL, f.fac_itbis ITBIS, f.fac_porccomision PORCOMIS');
    SQL.Add(',V.ven_nombre VENDEDOR');
    SQL.Add('FROM FACTURAS F, SUCURSALES S, VENDEDORES V');
    SQL.Add('WHERE F.EMP_CODIGO = S.EMP_CODIGO');
    SQL.Add('AND F.SUC_CODIGO = S.SUC_CODIGO');
    SQL.Add('AND F.ven_codigo = V.ven_codigo');
    SQL.Add('AND F.EMP_CODIGO = :EMP');
    SQL.Add('and v.ven_comision_venta = ''True''');
    if Trim(edVendedor.Text)<>'' then
    SQL.Add('AND f.VEN_CODIGO = :VEN');
    SQL.Add('AND F.FAC_COMISION > 0 ');
    SQL.Add('AND F.FAC_STATUS <> '+#39+'ANU'+#39);
    SQL.Add('AND F.FAC_FECHA BETWEEN convert(datetime,:FECHA1,105) AND convert(datetime,:FECHA2,105)');
    SQL.Add('AND F.FAC_FORMA = '+#39+'A'+#39);
    SQL.Add('ORDER BY F.FAC_FECHA');

    Parameters.ParamByName('emp').Value := dm.vp_cia;
    if Trim(edVendedor.Text)<>'' then
    Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
    Parameters.ParamByName('fecha1').DataType := ftDate;
    Parameters.ParamByName('fecha2').DataType := ftDate;
    Parameters.ParamByName('fecha1').Value := Fecha1.Date;
    Parameters.ParamByName('fecha2').Value := Fecha2.Date;
    Open;
    end;
    end;

    //----------------------------Recibos------------------
    if PageControl1.ActivePage = tsRecibos then begin
     With QConsulta do begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT');
      SQL.Add('S.suc_nombre SUCURSAL,RTRIM(R.REC_NUMEROMANUAL) FORMA, 1 TIPO, ');
      SQL.Add('R.REC_NUMERO NUM, ');
      SQL.Add('R.REC_FECHA FEC, R.REC_STATUS STA, R.REC_NOMBRE CLIENTE,');
      SQL.Add('R.REC_COMISION COMISION, R.REC_MONTO TOTAL, 0.00 ITBIS, r.rec_porccomision PORCOMIS');
      SQL.Add(',V.ven_nombre VENDEDOR');
      SQL.Add('FROM RECIBOS R, SUCURSALES S, VENDEDORES V');
      SQL.Add('WHERE R.EMP_CODIGO = S.EMP_CODIGO AND R.SUC_CODIGO = S.SUC_CODIGO AND R.emp_codigo = :EMP');
      SQL.Add('AND R.ven_codigo = V.ven_codigo');
      SQL.Add('AND R.REC_STATUS <> ''ANU''');
      SQL.Add('and v.ven_comision_venta = ''True''');
      SQL.Add('AND R.REC_FECHA BETWEEN convert(datetime,:FECHA1,105) AND convert(datetime,:FECHA2,105)');
      if Trim(edVendedor.Text)<>'' then
      SQL.Add('and R.VEN_CODIGO = :VEN ');
      SQL.Add('ORDER BY R.REC_FECHA');

      Parameters.ParamByName('emp').Value := dm.vp_cia;
      if Trim(edVendedor.Text)<>'' then
      Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
      Parameters.ParamByName('fecha1').DataType := ftDate;
      Parameters.ParamByName('fecha2').DataType := ftDate;
      Parameters.ParamByName('fecha1').Value := Fecha1.Date;
      Parameters.ParamByName('fecha2').Value := Fecha2.Date;
      Open;
     end;
     end;

     //----------------------------Devoluciones------------------
    if PageControl1.ActivePage = tsDevoluciones then begin
     With QConsulta do begin
      Close;
      SQL.Clear;
      SQL.Add('UPDATE DEVOLUCION');
      SQL.Add('SET dev_porccomision = F.fac_porccomision,');
      SQL.Add('dev_comision = (F.fac_total-F.FAC_ITBIS)*(F.fac_porccomision/100)');
      SQL.Add('FROM DEVOLUCION D');
      SQL.Add('INNER JOIN FACTURAS F ON D.EMP_CODIGO = F.EMP_CODIGO AND D.suc_codigo = F.suc_codigo AND D.fac_numero = F.fac_numero AND D.fac_forma = F.fac_forma AND D.tfa_codigo = F.tfa_codigo');
      SQL.Add('WHERE  F.FAC_COMISION > 0');
      ExecSQL;

      Close;
      SQL.Clear;
      SQL.Add('SELECT');
      SQL.Add('S.SUC_NOMBRE SUCURSAL, D.FAC_FORMA FORMA, TFA_CODIGO TIPO, D.DEV_NUMERO NUM, ');
      SQL.Add('D.DEV_FECHA FEC, D.DEV_STATUS STA, D.DEV_NOMBRE CLIENTE, d.dev_comision COMISION,');
      SQL.Add('(d.dev_total-d.dev_itbis) TOTAL, D.dev_itbis ITBIS, d.dev_porccomision PORCOMIS,');
      SQL.Add('V.ven_nombre VENDEDOR ');
      SQL.Add('FROM DEVOLUCION D, SUCURSALES S, VENDEDORES V');
      SQL.Add('WHERE D.EMP_CODIGO = S.EMP_CODIGO AND D.SUC_CODIGO = S.SUC_CODIGO AND D.EMP_CODIGO = :EMP');
      SQL.Add('AND D.DEV_STATUS <> ''ANU''');
      SQL.Add('AND D.DEV_FECHA BETWEEN convert(datetime,:FECHA1,105) AND convert(datetime,:FECHA2,105)');
      SQL.Add('AND D.ven_codigo = V.ven_codigo');
      SQL.Add('and v.ven_comision_venta = ''True''');
      if Trim(edVendedor.Text)<>'' then
      SQL.Add('and D.VEN_CODIGO = :VEN ');
      SQL.Add('ORDER BY D.DEV_FECHA');
      Parameters.ParamByName('emp').Value := dm.vp_cia;
      if Trim(edVendedor.Text)<>'' then
      Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
      Parameters.ParamByName('fecha1').DataType := ftDate;
      Parameters.ParamByName('fecha2').DataType := ftDate;
      Parameters.ParamByName('fecha1').Value := Fecha1.Date;
      Parameters.ParamByName('fecha2').Value := Fecha2.Date;
      Open;
     end;
     end;








    //----------------------------CARGOS BANCARIOS------------------ //
    if PageControl1.ActivePage = tsCargosBancarios then begin
     With QConsulta do begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT');
      SQL.Add('S.SUC_NOMBRE SUCURSAL, C.CAR_FORMA FORMA, 0 TIPO, C.CAR_NUMERO NUM, C.CAR_FECHA FEC,');
      SQL.Add('C.car_status STA, CL.CLI_NOMBRE CLIENTE,  C.CAR_COMISION COMISION, C.CAR_MONTO TOTAL, ');
      SQL.Add(' 0.00 ITBIS, 0.00 PORCOMIS, V.ven_nombre VENDEDOR');
      SQL.Add('FROM CARGOSBANCO C');
      SQL.Add('INNER JOIN SUCURSALES S  ON C.EMP_CODIGO = S.EMP_CODIGO');
      SQL.Add('INNER JOIN BANCOS B  ON C.EMP_CODIGO = B.EMP_CODIGO AND C.BAN_CODIGO = B.BAN_CODIGO');
      SQL.Add('INNER JOIN USUARIOS U  ON C.USU_CODIGO = U.USU_CODIGO');
      SQL.Add('LEFT JOIN CLIENTES CL  ON C.EMP_CODIGO = CL.EMP_CODIGO AND C.CLI_CODIGO = CL.CLI_CODIGO');
      sql.Add('LEFT JOIN RECIBOS R  ON C.EMP_CODIGO = R.EMP_CODIGO AND C.SUC_CODIGO = R.SUC_CODIGO AND C.REC_NUMERO = R.REC_NUMERO');
      SQL.Add('LEFT JOIN VENDEDORES V  ON R.EMP_CODIGO = V.EMP_CODIGO AND R.VEN_CODIGO = V.VEN_CODIGO');
      SQL.Add('WHERE C.car_status <> ''ANU''');
      SQL.Add('AND C.EMP_CODIGO = :EMP');
      SQL.Add('and v.ven_comision_venta = ''True''');
      SQL.Add('AND C.CAR_FECHA >= CAST(:fecha1 AS DATE) AND C.CAR_FECHA < CAST(DATEADD(DAY, 1, :fecha2) AS DATE)');
      if Trim(edVendedor.Text)<>'' then
      SQL.Add('and V.VEN_CODIGO = :VEN ');
      SQL.Add('ORDER BY C.CAR_FECHA');
      Parameters.ParamByName('emp').Value := dm.vp_cia;
      if Trim(edVendedor.Text)<>'' then
      Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
      Parameters.ParamByName('fecha1').DataType := ftDate;
      Parameters.ParamByName('fecha2').DataType := ftDate;
      Parameters.ParamByName('fecha1').Value := Fecha1.Date;
      Parameters.ParamByName('fecha2').Value := Fecha2.Date;
      Open;
     end;
     end;


     //----------------------------Ticket------------------
    if PageControl1.ActivePage = tsTicketPOS then begin
     With QConsulta do begin
      Close;
      SQL.Clear;
      SQL.Add('Select S.SUC_NOMBRE SUCURSAL, ''A'' FORMA, M.tfa_codigo TIPO, M.Ticket NUM, M.fecha FEC,');
      SQL.Add('M.nombre  CLIENTE, M.status as STA, M.tk_Monto_comision COMISION,');
      SQL.Add('(M.Total - M.itbis) TOTAL, M.itbis ITBIS, 0.00 PORCOMIS');
      SQL.Add(',V.ven_nombre VENDEDOR');
      SQL.Add('From dbo.Montos_Ticket M, Sucursales S, VENDEDORES V');
      SQL.Add('Where M.SUC_CODIGO = S.suc_codigo AND M.emp_codigo = S.emp_codigo');
      SQL.Add('AND M.emp_codigo = :EMP');
      SQL.Add('AND M.ven_codigo = V.ven_codigo');
      SQL.Add('and v.ven_comision_venta = ''True''');
      if Trim(edVendedor.Text)<>'' then
      SQL.Add('and M.ven_codigo = :VEN ');
      SQL.Add('  and M.status <> ''ANU'' ');
      SQL.Add('  and M.fecha BETWEEN convert(datetime,:FECHA1,105) ');
      SQL.Add('  AND convert(datetime,:FECHA2,105) ');
      SQL.Add('Order by M.Fecha ');

      Parameters.ParamByName('emp').Value := dm.vp_cia;
      if Trim(edVendedor.Text)<>'' then
      Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
      Parameters.ParamByName('fecha1').DataType := ftDate;
      Parameters.ParamByName('fecha2').DataType := ftDate;
      Parameters.ParamByName('fecha1').Value := Fecha1.Date;
      Parameters.ParamByName('fecha2').Value := Fecha2.Date;
      Open;
     end;
     end;

    //----------------------------PRODUCTOS------------------ // 
    if PageControl1.ActivePage = tsFacturasxProductos then begin
    with QConsulta do begin
    Close;
    SQL.Clear;
    SQL.Add('SELECT ');
    SQL.Add('S.suc_nombre SUCURSAL, F.FAC_FORMA FORMA, F.TFA_CODIGO TIPO, F.FAC_NUMERO NUM, F.FAC_FECHA FEC,');
    SQL.Add('F.FAC_STATUS STA, DF.pro_nombre CLIENTE, ');
    SQL.Add('ROUND((CASE WHEN P.par_itbisincluido = ''True'' then DF.det_precio / (1 + (DF.DET_ITBIS / 100)) else DF.det_precio end * DF.det_cantidad)  * (DF.porc_vendedor / 100),2) AS COMISION,');
    SQL.Add('ROUND((CASE WHEN P.par_itbisincluido = ''True'' then DF.det_precio / (1 + (DF.DET_ITBIS / 100)) else DF.det_precio end * DF.det_cantidad),2) AS TOTAL,');
    SQL.Add('ROUND((CASE WHEN P.par_itbisincluido = ''True'' then DF.det_precio / (1 + (DF.DET_ITBIS / 100)) else DF.det_precio end * DF.det_cantidad)*(DF.DET_ITBIS / 100),2) ITBIS');
    SQL.Add(',DF.porc_vendedor AS PORCOMIS, V.ven_nombre VENDEDOR');
    SQL.Add('FROM FACTURAS F');
    SQL.Add('INNER JOIN PARAMETROS P ON F.emp_codigo = P.emp_codigo');
    SQL.Add('INNER JOIN SUCURSALES S ON F.emp_codigo = S.emp_codigo AND F.suc_codigo = S.suc_codigo');
    SQL.Add('INNER JOIN Det_Factura DF ON F.EMP_CODIGO = DF.EMP_CODIGO  AND F.SUC_CODIGO = DF.SUC_CODIGO');
    SQL.Add('AND F.FAC_NUMERO = DF.FAC_NUMERO  AND F.tfa_codigo = DF.tfa_codigo');
    SQL.Add('AND F.FAC_FORMA = DF.FAC_FORMA');
    SQL.Add('inner join Vendedores V on df.emp_codigo = v.emp_codigo and df.ven_codigo = v.ven_codigo ');
    SQL.Add('WHERE F.FAC_STATUS <> ''ANU''');
    SQL.Add('and v.ven_comision_venta = ''True''');
    SQL.Add('AND F.EMP_CODIGO = :emp');
    SQL.Add('AND F.FAC_FECHA BETWEEN convert(datetime,:fecha1,105) AND convert(datetime,:fecha2,105)');
    if Trim(edVendedor.Text)<>'' then begin
    SQL.Add('AND DF.VEN_CODIGO = :ven');
    SQL.Add('ORDER BY V.ven_nombre, f.fac_fecha, F.fac_numero');
    end
    else
    SQL.Add('ORDER BY V.ven_nombre, F.fac_numero');
    Parameters.ParamByName('emp').Value := dm.vp_cia;
    if Trim(edVendedor.Text)<>'' then
    Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
    Parameters.ParamByName('fecha1').DataType := ftDate;
    Parameters.ParamByName('fecha2').DataType := ftDate;
    Parameters.ParamByName('fecha1').Value := Fecha1.Date;
    Parameters.ParamByName('fecha2').Value := Fecha2.Date;
    Open;
    end;
    end;

    Totalizar;

    Screen.Cursor := crDefault;
  end;

