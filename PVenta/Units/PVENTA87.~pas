      SQL.Add('AND D.DEV_FECHA BETWEEN convert(datetime,:FECHA1,105) AND convert(datetime,:FECHA2,105)');
      if Trim(edVendedor.Text)<>'' then
      SQL.Add('and D.VEN_CODIGO = :VEN ');
      SQL.Add('ORDER BY D.DEV_FECHA');
      Parameters.ParamByName('emp').Value := dm.vp_cia;
      if Trim(edVendedor.Text)<>'' then
      Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
      Parameters.ParamByName('fecha1').DataType := ftDate;
      Parameters.ParamByName('fecha2').DataType := ftDate;
      Parameters.ParamByName('fecha1').Value := Fecha1.Date;
      Parameters.ParamByName('fecha2').Value := Fecha2.Date;
      Open;
    end;

  end;

  if ((PageControl1.ActivePage = tsFacturasxProductos)) then
  begin
    With RConsComision.qProductos do begin
            close;
            sql.Clear;
            sql.add(QProductos.SQL.GetText);
            Parameters.ParamByName('emp').DataType := ftInteger;
            Parameters.ParamByName('emp').Value := dm.vp_cia;
            if Trim(edVendedor.Text)<>'' then begin
            Parameters.ParamByName('ven').DataType := ftInteger;
            Parameters.ParamByName('ven').Value := StrToInt(Trim(edVendedor.Text));
            end;
            Parameters.ParamByName('fecha1').DataType := ftDate;
            Parameters.ParamByName('fecha2').DataType := ftDate;
            Parameters.ParamByName('fecha1').Value := Fecha1.Date;
            Parameters.ParamByName('fecha2').Value := Fecha2.Date;
            Open;
    end;
    end;



    try
         RConsComision.QD_Factura.Enabled := QFacturas.Active;
         RConsComision.GF_Factura.Enabled := QFacturas.Active;

         RConsComision.QD_Devoluciones.Enabled := QDevol.Active;
         RConsComision.GF_Devoluciones.Enabled := QDevol.Active;

         RConsComision.QD_Recibo.Enabled := QRecibos.Active;
         RConsComision.GF_Recibo.Enabled := QRecibos.Active;

         RConsComision.QD_FacturaxProd.Enabled := QProductos.Active;
         RConsComision.GF_FacturaxProd.Enabled := QProductos.Active;

        RConsComision.PrinterSetup;
        RConsComision.qrdbtxtFAC_FORMA.Enabled := not (Sender = btnTickePos);
        RConsComision.qrdbtxtTFA_CODIGO.Enabled := not (Sender = btnTickePos);
        RConsComision.qrlTipo.Enabled := not (Sender = btnTickePos);
        RConsComision.qrlGrupo.Enabled := not (Sender = btnTickePos);

        if (Sender = btnTickePos)  then  begin
          RConsComision.qrdbtxtFAC_FORMA.DataSet := nil;
          RConsComision.qrdbtxtTFA_CODIGO.DataSet:=nil;

        end;


        RConsComision.Preview;
      finally
        RConsComision.Destroy;
      end;}
   except
     RConsComision.Destroy;
   end;
end;

procedure TfrmConsComision.FormKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
 { if (ssCtrl in Shift) and (ord(key) = 66) and (ssAlt in Shift) then
    cbGrupo.ItemIndex := 1;
  if (ssCtrl in Shift) and (ord(key) = 65) and (ssAlt in Shift) then
    cbGrupo.ItemIndex := 0;
  if (ssCtrl in Shift) and (ord(key) = 84) and (ssAlt in Shift) then
    cbGrupo.ItemIndex := 2;
