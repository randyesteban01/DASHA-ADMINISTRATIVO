  object QConsulta: TADOQuery
    Active = True
    Connection = DM.ADOSigma
    CursorType = ctStatic
    Parameters = <>
    SQL.Strings = (
      'SELECT '
      
        '    S.suc_nombre SUCURSAL, F.FAC_FORMA FORMA, F.TFA_CODIGO TIPO,' +
        ' F.FAC_NUMERO NUM, F.FAC_FECHA FEC,'
      '    F.FAC_STATUS STA, DF.pro_nombre CLIENTE, '
      
        '    ROUND((CASE WHEN P.par_itbisincluido = '#39'True'#39' then DF.det_pr' +
        'ecio / (1 + (DF.DET_ITBIS / 100)) else DF.det_precio end * DF.de' +
        't_cantidad)  '
      '    * (DF.porc_vendedor / 100),2) AS COMISION,'
      
        '    ROUND((CASE WHEN P.par_itbisincluido = '#39'True'#39' then DF.det_pr' +
        'ecio / (1 + (DF.DET_ITBIS / 100)) else DF.det_precio end * DF.de' +
        't_cantidad),2) AS TOTAL,'
      '    DF.porc_vendedor AS PORCOMIS,    '
      
        '    ROUND((CASE WHEN P.par_itbisincluido = '#39'True'#39' then DF.det_pr' +
        'ecio / (1 + (DF.DET_ITBIS / 100)) else DF.det_precio end * DF.de' +
        't_cantidad)*(DF.DET_ITBIS / 100),2) ITBIS'
      '    ,V.ven_nombre VENDEDOR'
      '    FROM FACTURAS F'
      '    INNER JOIN PARAMETROS P ON F.emp_codigo = P.emp_codigo'
      
        '    INNER JOIN SUCURSALES S ON F.emp_codigo = S.emp_codigo AND F' +
        '.suc_codigo = S.suc_codigo'
      
        '    INNER JOIN Det_Factura DF ON F.EMP_CODIGO = DF.EMP_CODIGO  A' +
        'ND F.SUC_CODIGO = DF.SUC_CODIGO'
      
        '    AND F.FAC_NUMERO = DF.FAC_NUMERO  AND F.tfa_codigo = DF.tfa_' +
        'codigo'
      '    AND F.FAC_FORMA = DF.FAC_FORMA'
      
        '    inner join Vendedores V on df.emp_codigo = v.emp_codigo and ' +
        'df.ven_codigo = v.ven_codigo '
