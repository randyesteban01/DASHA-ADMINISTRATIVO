unit PVENTA252;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, Buttons, DB, ADODB, DBCtrls, cxControls, cxContainer,
  cxEdit, cxTextEdit, cxMaskEdit, cxDropDownEdit, cxCalendar;

type
  TfrmeNCF = class(TForm)
    btgrabar: TBitBtn;
    BitBtn2: TBitBtn;
    Label2: TLabel;
    eNCFInicial: TEdit;
    Label4: TLabel;
    eNCFFinal: TEdit;
    Label5: TLabel;
    eNCFUltimo: TEdit;
    Label6: TLabel;
    LB_1: TLabel;
    eNCFFecha: TcxDateEdit;
    ChkB_Vencimiento: TCheckBox;
    eNCFCantidad: TEdit;
    Label1: TLabel;
    cboTipoeNCF: TDBLookupComboBox;
    QTipoeNCF: TADOQuery;
    dseNCF: TDataSource;
    QTipoeNCFcod_dgii: TIntegerField;
    QTipoeNCFnombre_dgii: TStringField;
    Label3: TLabel;
    eNCFCantidadMinima: TEdit;
    procedure FormKeyPress(Sender: TObject; var Key: Char);
    procedure FormCreate(Sender: TObject);
    
    procedure ChkB_VencimientoClick(Sender: TObject);
    procedure FormActivate(Sender: TObject);
    procedure eNCFInicialChange(Sender: TObject);
    procedure eNCFCantidadChange(Sender: TObject);
   
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  frmeNCF: TfrmeNCF;

implementation

uses SIGMA01, StdConvs;

{$R *.dfm}

procedure TfrmeNCF.FormKeyPress(Sender: TObject; var Key: Char);
begin
  if key = chr(vk_return) then
  begin
    perform(wm_nextdlgctl, 0, 0);
    key := #0;
  end;
end;

procedure TfrmeNCF.FormCreate(Sender: TObject);
begin      
  QTipoeNCF.Open;
end;



procedure TfrmeNCF.ChkB_VencimientoClick(Sender: TObject);
begin
if ChkB_Vencimiento.Checked = False then
eNCFFecha.Properties.ReadOnly  := True else
eNCFFecha.Properties.ReadOnly := False;
end;

procedure TfrmeNCF.FormActivate(Sender: TObject);
begin
ChkB_VencimientoClick(Sender);
end;



procedure TfrmeNCF.eNCFInicialChange(Sender: TObject);
var
inicial, cantidad: Double;
begin
   if TryStrToFloat(eNCFInicial.Text, inicial) and TryStrToFloat(eNCFCantidad.Text, cantidad) then
    eNCFFinal.Text := FloatToStr(inicial + cantidad - 1)
  else
    eNCFFinal.Text := '';
  

end;

procedure TfrmeNCF.eNCFCantidadChange(Sender: TObject);
var
inicial, cantidad: Double;
begin
   if TryStrToFloat(eNCFInicial.Text, inicial) and TryStrToFloat(eNCFCantidad.Text, cantidad) then
    eNCFFinal.Text := FloatToStr(inicial + cantidad - 1)
  else
    eNCFFinal.Text := '';
end;

end.
